<%- include('partials/head', { content }) %>

<%- include('partials/navbar', { content, pageType: 'blog' }) %>

    <main>
      <section class="section">
        <div class="container">
          <article class="glass-panel hover-card blog-card">
            <p class="eyebrow">Blog Post</p>
            <h1><%= post.title %></h1>
            
            <p class="muted">
              <%= post.publishDate || 'Draft' %>
              <% if (post.author) { %> • <%= post.author %><% } %>
              <% if (post.category) { %> • <%= post.category %><% } %>
            </p>


            <% if (post.imageUrl) { %>
                <div class="blogmedia">
                    <img src="<%= post.imageUrl %>" alt="<%= post.title %>" class="blog-post-media" />
                </div>
            <% } %>




            <% if (post.body) { %>
              <div class="section-copy rich-text"><%- post.body %></div>
            <% } else if (post.excerpt) { %>
              <div class="section-copy rich-text"><%= post.excerpt %></div>
            <% } %>

            <% if (post.videoUrl) { %>
                                <div class="blogmedia">

              <video class="blog-post-media" controls playsinline>
                <source src="<%= post.videoUrl %>" type="video/mp4" />
              </video>
                              </div>

            <% } %>


          </article>
        </div>
      </section>
    </main>

<%- include('partials/footer', { content, isAdmin }) %>

<script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
<script>
  (() => {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    document.querySelectorAll('.blog-card, .blog-post-media, .section-heading').forEach((element, index) => {
      element.setAttribute('data-aos', index === 0 ? 'fade-up' : 'zoom-in');
      element.setAttribute('data-aos-delay', String(Math.min(index * 80, 300)));
    });

    AOS.init({
      duration: 750,
      easing: 'ease-out-cubic',
      offset: 80,
      once: true,
      mirror: false,
      disable: prefersReducedMotion
    });
  })();
</script>
</body>
</html>