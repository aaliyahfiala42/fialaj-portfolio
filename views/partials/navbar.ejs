<%
  const navItems = content.toc || [];
  const isBlogPage = typeof pageType !== 'undefined' && pageType === 'blog';
  const homePrefix = isBlogPage ? '/#' : '#';
  const brandHref = isBlogPage ? '/#home' : '#home';
  const logoUrl = '/logo.png';

  const phone = content.site.phone || content.site.phoneNumber || '';
  const email = content.site.email || content.site.contactEmail || '';
  const linkedin = content.site.linkedin || content.site.linkedinUrl || '';
%>

<header class="topbar">
  <div class="contact-topbar" aria-label="Contact links">
    <div class="container contact-topbar-inner">
      <% if (phone) { %>
        <a class="contact-topbar-link" href="tel:<%= phone.replace(/\s+/g, '') %>">
          <i class="fa-solid fa-phone" aria-hidden="true"></i>
          <span><%= phone %></span>
        </a>
      <% } %>

      <% if (email) { %>
        <a class="contact-topbar-link" href="mailto:<%= email %>">
          <i class="fa-solid fa-envelope" aria-hidden="true"></i>
          <span><%= email %></span>
        </a>
      <% } %>

      <% if (linkedin) { %>
        <a class="contact-topbar-link" href="<%= linkedin %>" target="_blank" rel="noopener">
          <i class="fa-brands fa-linkedin-in" aria-hidden="true"></i>
          <span>LinkedIn</span>
        </a>
      <% } %>
    </div>
  </div>

  <div class="container topbar-inner">
    <a class="brand" href="<%= brandHref %>">
      <span class="brand-logo-wrap" aria-hidden="true">
        <% if (logoUrl) { %>
          <img src="<%= logoUrl %>" alt="" class="brand-logo" />
        <% } %>
      </span>

      <span class="brand-text">
        <span class="brand-name"><%= content.site.ownerName %></span>
        <small>Portfolio</small>
      </span>
    </a>

    <nav class="site-nav" data-site-nav aria-label="Main navigation">
      <% if (isBlogPage) { %>
        <a class="nav-utility-link" href="/#blog">Back to Blog</a>
      <% } %>

      <button
        class="nav-menu-button"
        type="button"
        data-nav-open
        aria-controls="siteSidebar"
        aria-expanded="false"
        aria-label="Open table of contents menu"
      >
        <span class="nav-menu-label">Table of Contents</span>
        <i class="fa-solid fa-bars" aria-hidden="true"></i>
      </button>

      <div class="nav-scrim" data-nav-scrim></div>

      <aside id="siteSidebar" class="nav-sidebar" data-nav-drawer aria-hidden="true">
        <div class="nav-sidebar-top">
          <div>
            <p class="eyebrow">Table of Contents</p>
            <h2>Explore Portfolio</h2>
          </div>

          <button class="nav-close-button" type="button" data-nav-close aria-label="Close menu">
            ×
          </button>
        </div>

        <a class="nav-home-link" href="<%= brandHref %>" data-nav-link>
          <span class="nav-index">00</span>
          <span>Home</span>
        </a>

        <div class="nav-sidebar-label">Portfolio Sections</div>

        <div class="nav-sidebar-links">
          <% navItems.forEach((item, index) => { %>
            <a href="<%= homePrefix + item.anchor %>" data-nav-link>
              <span class="nav-index"><%= String(index + 1).padStart(2, '0') %></span>
              <span><%= item.title %></span>
            </a>
          <% }) %>
        </div>
      </aside>
    </nav>
  </div>
</header>

<script>
  (() => {
    const nav = document.querySelector('[data-site-nav]');
    if (!nav) return;

    const openButton = nav.querySelector('[data-nav-open]');
    const closeButton = nav.querySelector('[data-nav-close]');
    const drawer = nav.querySelector('[data-nav-drawer]');
    const scrim = nav.querySelector('[data-nav-scrim]');
    const links = nav.querySelectorAll('[data-nav-link]');

    const setOpen = (isOpen) => {
      nav.classList.toggle('is-open', isOpen);
      openButton.setAttribute('aria-expanded', String(isOpen));
      drawer.setAttribute('aria-hidden', String(!isOpen));
      document.body.classList.toggle('nav-lock', isOpen);
    };

    openButton.addEventListener('click', () => {
      setOpen(!nav.classList.contains('is-open'));
    });

    closeButton.addEventListener('click', () => setOpen(false));
    scrim.addEventListener('click', () => setOpen(false));

    links.forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpen(false);
    });
  })();
</script>