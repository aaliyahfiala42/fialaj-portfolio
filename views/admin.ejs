                <section class="admin-card hover-card">
          <div class="admin-section-top">
            <div>
              <p class="eyebrow">References</p>
              <h2>Professional references with contact info</h2>
            </div>
            <button type="button" class="button button-secondary add-item" data-target="references">Add Reference</button>
          </div>
          <div id="referencesContainer" class="repeater-grid"></div>
        </section>

        <section class="admin-card hover-card">
          <div class="admin-section-top">
            <div>
              <p class="eyebrow">Letters of Recommendation</p>
              <h2>Upload or link recommendation PDFs</h2>
            </div>
            <button type="button" class="button button-secondary add-item" data-target="recommendationLetters">Add Letter</button>
          </div>
          <div id="recommendationLettersContainer" class="repeater-grid"></div>
        </section>

        <section class="admin-card hover-card">
          <div class="admin-section-top">
            <div>
              <p class="eyebrow">Blog</p>
              <h2>Create blog posts with optional photos and videos</h2>
            </div>
            <button type="button" class="button button-secondary add-item" data-target="blogPosts">Add Blog Post</button>
          </div>
          <div id="blogPostsContainer" class="repeater-grid"></div>
        </section>

        <% const career = content.careerPlanning || {}; %>
        <section class="admin-card hover-card">
          <div class="section-heading">
            <p class="eyebrow">Career Planning</p>
            <h2>Editable career planning content</h2>
          </div>

          <div class="admin-grid two-col-form">
            <label>
              <span>Target Career Field Title</span>
              <input type="text" name="careerFieldTitle" value="<%= career.targetCareerFieldTitle || '' %>" />
            </label>

            <label>
              <span>Job Outlook</span>
              <textarea name="careerJobOutlook" rows="5"><%= career.jobOutlook || '' %></textarea>
            </label>

            <label style="grid-column: 1 / -1;">
              <span>Target Career Field Summary</span>
              <textarea name="careerFieldSummary" rows="6"><%= career.targetCareerFieldSummary || '' %></textarea>
            </label>

            <label>
              <span>Required Qualifications (one per line)</span>
              <textarea name="careerRequiredQualifications" rows="6"><%= (career.requiredQualifications || []).join('\n') %></textarea>
            </label>

            <label>
              <span>Potential Employers (one per line)</span>
              <textarea name="careerPotentialEmployers" rows="6"><%= (career.potentialEmployers || []).join('\n') %></textarea>
            </label>

            <label>
              <span>Short-Term Plan Title</span>
              <input type="text" name="careerShortTermTitle" value="<%= career.shortTermTitle || '' %>" />
            </label>

            <label>
              <span>Long-Term Plan Title</span>
              <input type="text" name="careerLongTermTitle" value="<%= career.longTermTitle || '' %>" />
            </label>

            <label>
              <span>Short-Term Plan Text</span>
              <textarea name="careerShortTermText" rows="6"><%= career.shortTermText || '' %></textarea>
            </label>

            <label>
              <span>Long-Term Plan Text</span>
              <textarea name="careerLongTermText" rows="6"><%= career.longTermText || '' %></textarea>
            </label>

            <label>
              <span>Short-Term Milestones (one per line)</span>
              <textarea name="careerShortTermMilestones" rows="6"><%= (career.shortTermMilestones || []).join('\n') %></textarea>
            </label>

            <label>
              <span>Long-Term Milestones (one per line)</span>
              <textarea name="careerLongTermMilestones" rows="6"><%= (career.longTermMilestones || []).join('\n') %></textarea>
            </label>
          </div>
        </section>
        <div class="admin-actions sticky-submit">
          <button type="submit" class="button button-primary">Save All Changes</button>
        </div>
      </form>
    </main>
<%- include('partials/footer', { content }) %>

    <script id="admin-data" type="application/json"><%- JSON.stringify(content) %></script>
    <script src="/js/admin.js"></script>
  </body>
</html>
