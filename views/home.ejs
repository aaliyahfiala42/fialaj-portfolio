      <section id="certifications" class="section alt-surface">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">Certifications</p>
            <h2>Credentials and Training</h2>
          </div>
          <div class="tag-cloud">
            <% content.certifications.forEach((item) => { %>
              <span class="skill-tag hover-card"><%= item %></span>
            <% }) %>
          </div>
        </div>
      </section>

      <% const career = content.careerPlanning || {}; %>
      <section id="career-planning" class="section">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">Career Planning</p>
            <h2>Career Goals and Direction</h2>
          </div>

          <div class="card-grid three-up">
            <article class="info-card hover-card">
              <h3><%= career.targetCareerFieldTitle || 'Target Career Field' %></h3>
              <p><%= career.targetCareerFieldSummary || '' %></p>

              <% if (career.jobOutlook) { %>
                <p><strong>Job Outlook:</strong> <%= career.jobOutlook %></p>
              <% } %>

              <% if ((career.requiredQualifications || []).length) { %>
                <p class="muted">Required Qualifications</p>
                <div class="tag-cloud">
                  <% career.requiredQualifications.forEach((item) => { %>
                    <span class="skill-tag hover-card"><%= item %></span>
                  <% }) %>
                </div>
              <% } %>

              <% if ((career.potentialEmployers || []).length) { %>
                <p class="muted">Potential Employers</p>
                <div class="tag-cloud">
                  <% career.potentialEmployers.forEach((item) => { %>
                    <span class="skill-tag hover-card"><%= item %></span>
                  <% }) %>
                </div>
              <% } %>
            </article>

            <article class="info-card hover-card">
              <h3><%= career.shortTermTitle || 'Short-Term Career Plan (1 - 3 Years)' %></h3>
              <p class="preserve-whitespace"><%= career.shortTermText || '' %></p>
              <% if ((career.shortTermMilestones || []).length) { %>
                <ul class="detail-list">
                  <% career.shortTermMilestones.forEach((item) => { %>
                    <li><%= item %></li>
                  <% }) %>
                </ul>
              <% } %>
            </article>

            <article class="info-card hover-card">
              <h3><%= career.longTermTitle || 'Long-Term Career Plan (5 - 10 Years)' %></h3>
              <p class="preserve-whitespace"><%= career.longTermText || '' %></p>
              <% if ((career.longTermMilestones || []).length) { %>
                <ul class="detail-list">
                  <% career.longTermMilestones.forEach((item) => { %>
                    <li><%= item %></li>
                  <% }) %>
                </ul>
              <% } %>
            </article>
          </div>
        </div>
      </section>

      <section id="contact" class="section contact-section alt-surface">
        <div class="container two-column">
          <div>
            <div class="section-heading">
              <p class="eyebrow">Contact Info</p>
              <h2>Let’s Connect</h2>
            </div>
            <p class="section-copy">Jennifer is passionate about leadership, access, advocacy, and creating positive change. Reach out for networking, collaboration, or future opportunities.</p>
          </div>
          <div class="contact-card hover-card">
            <a href="tel:<%= content.site.phone %>"><strong>Phone:</strong> <%= content.site.phone %></a>
            <a href="mailto:<%= content.site.email %>"><strong>Email:</strong> <%= content.site.email %></a>
            <a href="https://www.linkedin.com/in/jennifer-fiala-93b2b6404/"><strong>LinkedIn:</strong> View Profile</a>

            <% if (content.site.resumeUrl) { %>
              <a href="<%= content.site.resumeUrl %>" target="_blank" rel="noreferrer"><strong>Resume:</strong> Open resume</a>
            <% } %>

            <% if (content.site.coverLetterUrl) { %>
              <a href="<%= content.site.coverLetterUrl %>" target="_blank" rel="noreferrer"><strong>Cover Letter:</strong> Open cover letter</a>
            <% } %>
       </div>
        </div>
      </section>
    </main>


    <div class="project-viewer-modal" id="projectViewerModal" aria-hidden="true">
  <div class="project-viewer-backdrop" data-close-project-viewer></div>

  <div class="project-viewer-panel" role="dialog" aria-modal="true" aria-labelledby="projectViewerTitle">
    <div class="project-viewer-header">
      <div>
        <p class="eyebrow">Project Preview</p>
        <h2 id="projectViewerTitle">Project Viewer</h2>
      </div>

      <div class="project-viewer-actions">
        <a id="projectViewerDownload" class="button button-secondary downloadbtn" href="#" download>  <i class="fa-solid fa-download" aria-hidden="true"></i></a>
        <button type="button" class="project-viewer-close" data-close-project-viewer aria-label="Close project viewer">
          ×
        </button>
      </div>
    </div>

    <div class="project-viewer-body" id="projectViewerBody">
      <p class="muted">Select a project to preview.</p>
    </div>
  </div>
</div>

<%- include('partials/footer', { content, isAdmin }) %>
<script>
  (() => {
    const modal = document.getElementById('projectViewerModal');
    const viewerBody = document.getElementById('projectViewerBody');
    const viewerTitle = document.getElementById('projectViewerTitle');
    const viewerDownload = document.getElementById('projectViewerDownload');

    if (!modal || !viewerBody || !viewerTitle || !viewerDownload) return;

    const getExtension = (url) => {
      const cleanUrl = String(url || '').split('?')[0].split('#')[0];
      return cleanUrl.includes('.') ? cleanUrl.split('.').pop().toLowerCase() : '';
    };

    const absoluteUrl = (url) => {
      try {
        return new URL(url, window.location.origin).href;
      } catch (_error) {
        return url;
      }
    };

    const isImage = (ext) => ['jpg', 'jpeg', 'png', 'gif', 'webp', 'svg'].includes(ext);
    const isVideo = (ext) => ['mp4', 'webm', 'mov', 'm4v'].includes(ext);
    const isPdf = (ext) => ext === 'pdf';
    const isOffice = (ext) => ['ppt', 'pptx', 'doc', 'docx', 'xls', 'xlsx'].includes(ext);

    const openViewer = ({ fileUrl, title }) => {
      const ext = getExtension(fileUrl);
      const fullUrl = absoluteUrl(fileUrl);

      viewerTitle.textContent = title || 'Project Viewer';
      viewerDownload.href = fileUrl;
      viewerDownload.setAttribute('download', '');

      if (isPdf(ext)) {
        viewerBody.innerHTML = `
          <iframe
            class="project-viewer-frame"
            src="${fileUrl}#toolbar=1&navpanes=0"
            title="${title || 'Project PDF'}"
          ></iframe>
        `;
      } else if (isImage(ext)) {
        viewerBody.innerHTML = `
          <img
            class="project-viewer-image"
            src="${fileUrl}"
            alt="${title || 'Project image'}"
          />
        `;
      } else if (isVideo(ext)) {
        viewerBody.innerHTML = `
          <video
            class="project-viewer-video"
            src="${fileUrl}"
            controls
          ></video>
        `;
      } else if (isOffice(ext)) {
        viewerBody.innerHTML = `
          <iframe
            class="project-viewer-frame"
            src="https://view.officeapps.live.com/op/embed.aspx?src=${encodeURIComponent(fullUrl)}"
            title="${title || 'Office project'}"
          ></iframe>
        `;
      } else {
        viewerBody.innerHTML = `
          <div class="project-viewer-fallback">
            <div>
              <h3>Preview unavailable</h3>
              <p class="muted">This file type may not support in-browser preview. You can still download the project.</p>
              <a class="button button-primary" href="${fileUrl}" download>Download Project</a>
            </div>
          </div>
        `;
      }

      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.classList.add('nav-lock');
    };

    const closeViewer = () => {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      viewerBody.innerHTML = '<p class="muted">Select a project to preview.</p>';
      document.body.classList.remove('nav-lock');
    };

    document.addEventListener('click', (event) => {
      const previewButton = event.target.closest('.project-preview-button');

      if (previewButton) {
        openViewer({
          fileUrl: previewButton.dataset.fileUrl,
          title: previewButton.dataset.projectTitle
        });
        return;
      }

      if (event.target.closest('[data-close-project-viewer]')) {
        closeViewer();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modal.classList.contains('is-open')) {
        closeViewer();
      }
    });
  })();
</script>

<script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
<script>
  (() => {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const applyAos = (selector, animation, delayStep = 0) => {
      document.querySelectorAll(selector).forEach((element, index) => {
        if (!element.hasAttribute('data-aos')) {
          element.setAttribute('data-aos', animation);
        }

        if (delayStep && !element.hasAttribute('data-aos-delay')) {
          element.setAttribute('data-aos-delay', String(Math.min(index * delayStep, 350)));
        }
      });
    };

    applyAos('.hero-copy', 'fade-right');
    applyAos('.hero-profile', 'fade-left');

    applyAos('.section-heading', 'fade-up');
    applyAos('.feature-banner-inner', 'zoom-in');

    applyAos('.toc-card', 'fade-up', 60);
    applyAos('.info-card', 'fade-up', 70);
    applyAos('.experience-card', 'fade-up', 70);
    applyAos('.skill-tag', 'zoom-in', 45);
    applyAos('.leadership-feature-card', 'fade-right');
applyAos('.leadership-side-grid .info-card', 'fade-left', 70);
    applyAos('.check-card', 'fade-up', 65);
    applyAos('.awards-feature-card', 'fade-right');
applyAos('.accomplishment-card', 'fade-up', 65);
    applyAos('.contact-card', 'fade-left');
    applyAos('.button-cluster', 'fade-left');

    AOS.init({
      duration: 750,
      easing: 'ease-out-cubic',
      offset: 80,
      once: true,
      mirror: false,
      disable: prefersReducedMotion
    });
  })();
</script>
</body>
</html>