<%- include('partials/head', { content }) %>

<%- include('partials/navbar', { content, isAdmin, pageType: 'home' }) %>

    <main>
      <section id="home" class="hero-section">
        <video class="hero-video" autoplay muted loop playsinline poster="<%= content.site.heroPoster %>">
          <source src="<%= content.site.heroVideo %>" type="video/mp4" />
        </video>
        <div class="hero-overlay"></div>

        <div class="container hero-content">
          <div class="hero-grid">
            <div class="hero-copy glass-panel hover-card">
              <p class="eyebrow"><%= content.site.program %></p>
              <h1><%= content.site.ownerName %></h1>
              <h2><%= content.site.heroTitle %></h2>
              <p class="hero-tagline"><%= content.site.tagline %></p>
              <p class="hero-subtitle"><%= content.site.professionalTitle %></p>
              <p class="hero-intro"><%= content.introStatement %></p>


            </div>

            <div class="hero-profile glass-panel hover-card">
              <div class="profile-photo-wrap">
                <img src="<%= content.site.profileImage %>" alt="<%= content.site.ownerName %> profile photo" class="profile-photo" />
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section toc-section">
        <div class="container">
          <div class="section-heading center">
            <p class="eyebrow">Table of Contents</p>
            <h2>Navigate Jennifer’s Portfolio</h2>
          </div>
          <div class="toc-grid">
            <% content.toc.forEach((item, index) => { %>
              <a class="toc-card hover-card" href="#<%= item.anchor %>">
                <span class="toc-index"><%= String(index + 1).padStart(2, '0') %></span>
                <span class="toc-title"><%= item.title %></span>
              </a>
            <% }) %>
          </div>
        </div>
      </section>

      <section id="about" class="section alt-surface">
        <div class="container two-column">
          <div>
            <div class="section-heading">
              <p class="eyebrow">About Me</p>
              <h2>Leading with Empathy, Purpose, and Service</h2>
            </div>
            <p class="section-copy"><%= content.introStatement %></p>
          </div>
          <div class="stats-grid">
            <article class="info-card hover-card">
              <h3>Program</h3>
              <p><%= content.site.program %></p>
            </article>
            <article class="info-card hover-card">
              <h3>Academic Goal</h3>
              <p>Complete a BAS in Organizational Leadership & Technical Management in 2026.</p>
            </article>
            <article class="info-card hover-card">
              <h3>Career Focus</h3>
              <p>Expand access to essential resources for individuals with disabilities.</p>
            </article>
            <article class="info-card hover-card">
              <h3>Leadership Style</h3>
              <p>Create inclusive spaces where team members feel heard, valued, and supported.</p>
            </article>
          </div>
        </div>
      </section>

      <section id="overview" class="section feature-banner" style="background-image: linear-gradient(rgba(38, 34, 31, 0.35), rgba(38, 34, 31, 0.55)), url('<%= content.site.featureBackground %>');">
        <div class="container feature-banner-inner">
          <p class="eyebrow light" style="color: #fff;">Jennifer’s Portfolio</p>
          <h2>Inspiring Growth. Empowering Success.<br/> Leading with Empathy.</h2>
        </div>
      </section>

      <section id="education" class="section">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">Education</p>
            <h2>Academic Background</h2>
          </div>
          <div class="card-grid two-up">
            <% content.education.forEach((item) => { %>
              <article class="info-card hover-card timeline-card">
                <span class="card-kicker"><%= item.year %></span>
                <h3><%= item.degree %></h3>
                <p class="muted"><%= item.school %></p>
                <p><%= item.description %></p>
              </article>
            <% }) %>
          </div>
        </div>
      </section>

      <section id="experience" class="section alt-surface">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">Work Experience</p>
            <h2>Professional Journey</h2>
          </div>
          <div class="stack-grid">
            <% content.workExperience.forEach((item) => { %>
              <article class="experience-card hover-card">
                <div>
                  <p class="card-kicker"><%= item.dates %></p>
                  <h3><%= item.role %></h3>
                  <p class="muted"><%= item.employer %></p>
                </div>
                <p><%= item.description %></p>
              </article>
            <% }) %>
          </div>
        </div>
      </section>

      <section id="skills" class="section">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">Skills & Competencies</p>
            <h2>Strengths That Support Impact</h2>
          </div>
          <div class="tag-cloud">
            <% content.skills.forEach((skill) => { %>
              <span class="skill-tag hover-card"><%= skill %></span>
            <% }) %>
          </div>
        </div>
      </section>

      <section id="resume" class="section alt-surface">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">Resume</p>
            <h2>Professional Documents</h2>
          </div>

          <div class="document-grid">
            <article class="document-card hover-card">
              <div>
                <h3>Resume</h3>
                <p>View Jennifer’s current professional resume.</p>
                <% if (content.site.resumeUrl) { %>
                  <a class="button button-primary" href="<%= content.site.resumeUrl %>" target="_blank" rel="noreferrer">Open Resume</a>
                <% } else { %>
                  <span class="button button-secondary button-disabled">Resume Coming Soon</span>
                <% } %>
              </div>
            </article>

            <article class="document-card hover-card">
              <div>
                <h3>Cover Letter</h3>
                <p>View Jennifer’s professional cover letter.</p>
                <% if (content.site.coverLetterUrl) { %>
                  <a class="button button-secondary" href="<%= content.site.coverLetterUrl %>" target="_blank" rel="noreferrer">Open Cover Letter</a>
                <% } else { %>
                  <span class="button button-secondary button-disabled">Cover Letter Coming Soon</span>
                <% } %>
              </div>
            </article>
          </div>
        </div>
      </section>

      <section id="references" class="section">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">References and Recommendations</p>
            <h2>Professional References & Supporting Letters</h2>
          </div>

          <div class="">
            <div>
              <div class="section-heading">
                <p class="eyebrow">References</p>
              </div>

              <div class="stack-grid">
                <% if ((content.references || []).length) { %>
                  <% content.references.forEach((reference) => { %>
                    <article class="info-card hover-card">
                      <h3><%= reference.name %></h3>

                      <% if (reference.role || reference.organization) { %>
                        <p class="muted"><%= [reference.role, reference.organization].filter(Boolean).join(' • ') %></p>
                      <% } %>

                      <% if (reference.connection) { %>
                        <p><strong>Connection:</strong> <%= reference.connection %></p>
                      <% } %>

                      <% if (reference.notes) { %>
                        <p><%= reference.notes %></p>
                      <% } %>

                      <% if (reference.email) { %>
                        <p><a href="mailto:<%= reference.email %>" class="text-link"><strong>Email:</strong> <%= reference.email %></a></p>
                      <% } %>
                      <% if (reference.phone) { %>
                        <p><a href="tel:<%= reference.phone %>" class="text-link"><strong>Phone:</strong> <%= reference.phone %></a></p>
                      <% } %>
                      <% if (reference.linkedinUrl) { %>
                        <p><a href="<%= reference.linkedinUrl %>" target="_blank" rel="noreferrer" class="text-link"><strong>LinkedIn:</strong> View profile</a></p>
                      <% } %>
                    </article>
                  <% }) %>
                <% } else { %>
                  <article class="info-card hover-card">
                    <h3>No references added yet</h3>
                    <p>Add references from the admin dashboard.</p>
                  </article>
                <% } %>
              </div>
            </div>

            <div>
              <div class="section-heading">
                <p class="eyebrow">Letters of Recommendation</p>
              </div>

              <div class="stack-grid">
                <% if ((content.recommendationLetters || []).length) { %>
                  <% content.recommendationLetters.forEach((letter) => { %>
                    <article class="info-card hover-card">
                      <h3><%= letter.title %></h3>

                      <% if (letter.recommenderName || letter.relationship) { %>
                        <p class="muted"><%= [letter.recommenderName, letter.relationship].filter(Boolean).join(' • ') %></p>
                      <% } %>

                      <% if (letter.description) { %>
                        <p><%= letter.description %></p>
                      <% } %>

                      <% if (letter.pdfUrl) { %>
                        <a href="<%= letter.pdfUrl %>" target="_blank" rel="noreferrer" class="text-link">Open Recommendation PDF</a>
                      <% } %>
                    </article>
                  <% }) %>
                <% } else { %>
                  <article class="info-card hover-card">
                    <h3>No letters uploaded yet</h3>
                    <p>Upload recommendation PDFs from the admin dashboard.</p>
                  </article>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </section>

<section id="projects" class="section alt-surface">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Academic Projects & Work Samples</p>
      <h2>Portfolio Highlights</h2>
    </div>

    <div class="card-grid two-up">
      <% if ((content.projects || []).length) { %>
        <% content.projects.forEach((project) => { %>
          <article class="info-card hover-card project-card">
            <div class="project-card-top">
              <div>
                <p class="card-kicker">Work Sample</p>
                <h3><%= project.title %></h3>
              </div>
            </div>

            <% if (project.description) { %>
              <p><%= project.description %></p>
            <% } %>

            <div class="project-actions">
              <% if (project.link) { %>
                <a href="<%= project.link %>" target="_blank" rel="noreferrer" class="button button-secondary">Open Project Link</a>
              <% } %>

              <% if (project.fileUrl) { %>
                <a href="<%= project.fileUrl %>" target="_blank" rel="noreferrer" class="button button-primary">View Project</a>
              <% } %>
            </div>
          </article>
        <% }) %>
      <% } else { %>
        <article class="info-card hover-card">
          <h3>No projects added yet</h3>
          <p>Add projects and work sample files from the admin dashboard.</p>
        </article>
      <% } %>
    </div>
  </div>
</section>

      <section id="blog" class="section">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">Blog</p>
            <h2>Articles, Reflections, and Updates</h2>
          </div>

          <% const blogPosts = (content.blogPosts || []).slice().sort((a, b) => String(b.publishDate || '').localeCompare(String(a.publishDate || ''))); %>

          <div class="card-grid three-up">
            <% if (blogPosts.length) { %>
              <% blogPosts.forEach((post) => { %>
                <article class="info-card hover-card">
                  <% if (post.imageUrl) { %>
                    <img src="<%= post.imageUrl %>" alt="<%= post.title %>" class="blog-card-media" />
                  <% } %>

                  <p class="card-kicker">
                    <%= post.publishDate || 'Draft' %>
                    <% if (post.category) { %> • <%= post.category %><% } %>
                  </p>

                  <h3><%= post.title %></h3>

                  <% if (post.excerpt) { %>
                    <p><%= post.excerpt %></p>
                  <% } %>

                  <a href="/blog/<%= post.slug %>" class="text-link">Read Full Post</a>
                </article>
              <% }) %>
            <% } else { %>
              <article class="info-card hover-card">
                <h3>No blog posts yet</h3>
                <p>Create a post in the admin dashboard to show it here.</p>
              </article>
            <% } %>
          </div>
        </div>
      </section>

      <section id="accomplishments" class="section alt-surface">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow">Accomplishments</p>
            <h2>Milestones and Impact</h2>
          </div>
          <div class="check-grid">
            <% content.accomplishments.forEach((item) => { %>
              <article class="check-card hover-card">
                <span class="check-mark">✿</span>
                <p><%= item %></p>
              </article>
            <% }) %>
          </div>
        </div>
      </section>

<section id="volunteer" class="section">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Clubs, Affiliations, & Volunteer Work</p>
      <h2>Service-Centered Leadership</h2>
    </div>

    <div class="card-grid three-up">
      <% content.volunteerWork.forEach((item) => { %>
        <article class="info-card hover-card volunteer-card">
          <div class="volunteer-logo-wrap">
            <% if (item.logoUrl) { %>
              <img
                src="<%= item.logoUrl %>"
                alt="<%= item.organization %> logo"
                class="volunteer-logo"
              />
            <% } else { %>
              <div class="volunteer-logo-placeholder" aria-hidden="true">
                <i class="fa-solid fa-seedling"></i>
              </div>
            <% } %>
          </div>

          <p class="card-kicker"><%= item.dates %></p>
          <h3><%= item.organization %></h3>
          <p class="muted"><%= item.role %></p>
          <p><%= item.description %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>

